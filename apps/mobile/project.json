{
  "name": "mobile",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/mobile/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/mobile",
        "browser": "apps/mobile/src/main.ts",
        "tsConfig": "apps/mobile/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/mobile/public"
          }
        ],
        "styles": [
          "apps/mobile/src/styles.scss",
          "libs/shared/ui-kit/src/lib/theme.scss"
        ]
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/mobile/src/environments/environment.ts",
              "with": "apps/mobile/src/environments/environment.prod.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "1.5mb",
              "maximumError": "2mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        },
        "mock": {
          "fileReplacements": [
            {
              "replace": "apps/mobile/src/environments/environment.ts",
              "with": "apps/mobile/src/environments/environment.mock.ts"
            },
            {
              "replace": "libs/mobile/settings/src/lib/settings.providers.ts",
              "with": "libs/mobile/settings/src/lib/settings.providers.mock.ts"
            },
            {
              "replace": "libs/mobile/onboarding/src/lib/onboarding.providers.ts",
              "with": "libs/mobile/onboarding/src/lib/onboarding.providers.mock.ts"
            }
          ],
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "mobile:build:production"
        },
        "development": {
          "buildTarget": "mobile:build:development"
        },
        "mock": {
          "buildTarget": "mobile:build:mock"
        },
        "emulator": {
          "buildTarget": "mobile:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "serve-emulator": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "target": "build",
          "projects": ["functions"],
          "configuration": "development"
        }
      ],
      "options": {
        "commands": [
          "npx firebase emulators:start --project vultus-cab62",
          "pnpm nx serve mobile --configuration=emulator"
        ],
        "parallel": true
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "mobile:build",
        "staticFilePath": "dist/apps/mobile/browser",
        "spa": true
      }
    },
    "android": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "pnpm nx run mobile:build",
          "pnpm nx run mobile:sync",
          "pnpm nx run mobile:open"
        ]
      }
    },
    "sync": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx cap sync android"
      },
      "dependsOn": ["build"]
    },
    "open": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx cap open android"
      },
      "dependsOn": ["build"]
    }
  }
}
