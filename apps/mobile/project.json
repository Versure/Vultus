{
  "name": "mobile",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/mobile/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/mobile",
        "browser": "apps/mobile/src/main.ts",
        "tsConfig": "apps/mobile/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/mobile/public"
          }
        ],
        "styles": [
          "apps/mobile/src/styles.scss",
          "libs/shared/ui-kit/src/lib/theme.scss"
        ]
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/mobile/src/environments/environment.ts",
              "with": "apps/mobile/src/environments/environment.generated.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "1.5mb",
              "maximumError": "2mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "8kb",
              "maximumError": "12kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        },
        "mock": {
          "fileReplacements": [
            {
              "replace": "apps/mobile/src/environments/environment.ts",
              "with": "apps/mobile/src/environments/environment.mock.ts"
            },
            {
              "replace": "libs/mobile/settings/src/lib/settings.providers.ts",
              "with": "libs/mobile/settings/src/lib/settings.providers.mock.ts"
            },
            {
              "replace": "libs/mobile/onboarding/src/lib/onboarding.providers.ts",
              "with": "libs/mobile/onboarding/src/lib/onboarding.providers.mock.ts"
            },
            {
              "replace": "libs/mobile/notifications/src/lib/notifications.providers.ts",
              "with": "libs/mobile/notifications/src/lib/notifications.providers.mock.ts"
            }
          ],
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        },
        "prod-debug": {
          "fileReplacements": [
            {
              "replace": "apps/mobile/src/environments/environment.ts",
              "with": "apps/mobile/src/environments/environment.generated.ts"
            }
          ],
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "mobile:build:production"
        },
        "development": {
          "buildTarget": "mobile:build:development"
        },
        "mock": {
          "buildTarget": "mobile:build:mock"
        },
        "emulator": {
          "buildTarget": "mobile:build:development"
        },
        "prod-debug": {
          "buildTarget": "mobile:build:prod-debug"
        }
      },
      "defaultConfiguration": "development"
    },
    "serve-mock": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm nx serve mobile --configuration=mock"
      }
    },
    "serve-emulator": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "target": "build",
          "projects": ["functions"],
          "configuration": "development"
        }
      ],
      "options": {
        "commands": [
          "npx firebase emulators:start --project vultus-cab62",
          "pnpm nx serve mobile --configuration=emulator"
        ],
        "parallel": true
      }
    },
    "serve-prod-debug": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "node tools/scripts/inject-mobile-env.mjs",
          "pnpm nx serve mobile --configuration=prod-debug"
        ],
        "parallel": false
      }
    },
    "serve-prod": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "node tools/scripts/inject-mobile-env.mjs",
          "pnpm nx serve mobile --configuration=production"
        ],
        "parallel": false
      }
    },
    "inject-env": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/inject-mobile-env.mjs"
      }
    },
    "android-usb": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "node tools/scripts/inject-mobile-env.mjs",
          "node tools/scripts/inject-mobile-env.mjs --check-native",
          "pnpm nx run mobile:build",
          "npx cap sync android",
          "npx cap run android"
        ],
        "parallel": false
      }
    },
    "sync": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx cap sync android"
      },
      "dependsOn": ["build"]
    }
  }
}
