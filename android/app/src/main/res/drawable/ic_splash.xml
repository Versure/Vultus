<?xml version="1.0" encoding="utf-8"?>
<!--
  Boot-splash glyph — Material Symbols "movie_filter" (FILL 1), the same icon the
  animated web splash (SplashComponent) centers. Shared by the Android 12+ system
  splash (windowSplashScreenAnimatedIcon) and the Capacitor native splash
  (@drawable/splash), so the native boot layers and the web splash share one
  identity: the handoff native -> web reads as a single splash, not a second one.

  Path verbatim from the web splash SVG (viewBox "0 -960 960 960"); the inner
  <group> shifts it into the 0..960 viewport, the outer group insets it to ~72%
  so it clears the system splash's circular icon area. Colour = the vultus-primary
  emerald #4EDEA3 (docs/design/vultus-design-system.md).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="960"
    android:viewportHeight="960">
    <group
        android:pivotX="480"
        android:pivotY="480"
        android:scaleX="0.72"
        android:scaleY="0.72">
        <group android:translateY="960">
            <path
                android:fillColor="#4EDEA3"
                android:pathData="m366-518-34 78-78 34 78 34 34 78 34-78 78-34-78-34-34-78Zm266-12-25 54-54 25 54 25 25 54 25-54 54-25-54-25-25-54ZM140-800l74 152h130l-74-152h89l74 152h130l-74-152h89l74 152h130l-74-152h112q24 0 42 18t18 42v520q0 24-18 42t-42 18H140q-24 0-42-18t-18-42v-520q0-24 18-42t42-18Z" />
        </group>
    </group>
</vector>
