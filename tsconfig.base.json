{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2022",
    "module": "esnext",
    "lib": ["es2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "strict": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "paths": {
      "@vultus/shared/domain": ["./libs/shared/domain/src/index.ts"],
      "@vultus/shared/domain/tokens": ["./libs/shared/domain/src/tokens.ts"],
      "@vultus/shared/firestore-schema": [
        "./libs/shared/firestore-schema/src/index.ts"
      ],
      "@vultus/shared/ui-kit": ["./libs/shared/ui-kit/src/index.ts"],
      "@vultus/functions/sync-titles": [
        "./libs/functions/sync-titles/src/index.ts"
      ],
      "@vultus/mobile/notifications": [
        "./libs/mobile/notifications/src/index.ts"
      ],
      "@vultus/mobile/onboarding": ["./libs/mobile/onboarding/src/index.ts"],
      "@vultus/mobile/watchlist": ["./libs/mobile/watchlist/src/index.ts"],
      "@vultus/mobile/search": ["./libs/mobile/search/src/index.ts"],
      "@vultus/mobile/settings": ["./libs/mobile/settings/src/index.ts"],
      "@vultus/mobile/title-detail": [
        "./libs/mobile/title-detail/src/index.ts"
      ],
      "@vultus/functions/dispatch-notifications": [
        "./libs/functions/dispatch-notifications/src/index.ts"
      ],
      "@vultus/functions/sync-episodes": [
        "./libs/functions/sync-episodes/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
