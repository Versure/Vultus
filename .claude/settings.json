{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-slice-edits.mjs"
            ]
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(*Copy-Item*google-services.json*)",
      "Bash(*Copy-Item*.env.local*)",
      "Bash(*Copy-Item*environment.generated.ts*)"
    ]
  }
}
